# Firebase web app config — copy from Firebase console → Project settings → Your apps → SDK setup
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google OAuth client (Desktop or Web type) — Google Cloud Console → APIs & Services → Credentials
# For Electron, create a "Web application" OAuth client and add http://localhost as an authorized redirect URI.
VITE_GOOGLE_OAUTH_CLIENT_ID=
VITE_GOOGLE_OAUTH_CLIENT_SECRET=

# EmailJS — invite emails (emailjs.com → Account / Email Services / Email Templates)
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PRIVATE_KEY=
